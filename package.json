{
  "name": "micro-journal",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:dev": "vitest",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-mono": "^5.2.9",
    "@mdi/font": "7.4.47",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intellectronica/ruler": "^0.3.44",
    "@ionic/prettier-config": "^4.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-vuetify": "^4.7.2",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4",
    "resize-observer-polyfill": "^1.5.1",
    "sass-embedded": "^1.100.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.1.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,md,json}": [
      "prettier --write",
      "eslint"
    ]
  },
  "prettier": "@ionic/prettier-config",
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
